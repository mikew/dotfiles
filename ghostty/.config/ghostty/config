font-thicken = true

font-family = Iosevka Custom Slab
font-family-bold = Iosevka Custom Slab Bold
font-family-italic = Iosevka Custom Slab Oblique
font-family-bold-italic = Iosevka Custom Slab Bold Oblique

font-feature = -calt
font-feature = -liga
font-feature = -dlig

font-size = 14

theme = Oceanic Next

window-width = 120
window-height = 40

macos-option-as-alt = true
bold-is-bright = true

term = xterm-256color

window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true
